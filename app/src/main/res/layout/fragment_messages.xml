<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="@dimen/content_padding"
    android:layoutDirection="rtl"
    android:layout_marginTop="@dimen/safe_area_margin_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nav_messages"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="@dimen/content_margin_vertical"
        android:layout_marginBottom="@dimen/content_margin_vertical"
        android:background="@color/divider" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="لا توجد رسائل حالياً"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:layout_gravity="center_horizontal"
        tools:ignore="HardcodedText" />

</LinearLayout>
