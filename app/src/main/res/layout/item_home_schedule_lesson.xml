<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/home_schedule_card_fill"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="1dp"
    app:strokeColor="@color/home_schedule_card_stroke"
    app:strokeWidth="1dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/home_schedule_card_padding_h"
        android:paddingTop="@dimen/home_schedule_card_padding_v"
        android:paddingEnd="@dimen/home_schedule_card_padding_h"
        android:paddingBottom="@dimen/home_schedule_card_padding_v">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/home_schedule_subject"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/text_primary"
                tools:text="الرياضيات" />

            <TextView
                android:id="@+id/home_schedule_today_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_schedule_today_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/home_schedule_today_badge"
                android:textColor="@color/home_schedule_today_badge_text"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/home_schedule_past_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_schedule_past_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="@string/home_lesson_past_badge"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <TextView
            android:id="@+id/home_schedule_topic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="4dp"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/text_secondary"
            tools:text="موضوع الدرس" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            android:background="@color/divider" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_col_when"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/home_schedule_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="@color/text_primary"
            tools:text="2026/04/27 10:00" />

        <LinearLayout
            android:id="@+id/home_schedule_row_price"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_col_price"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/home_schedule_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/text_primary"
                tools:text="50" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/home_schedule_row_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_col_phone"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/home_schedule_phone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textIsSelectable="true"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/text_primary"
                tools:text="05xxxxxxxx" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/home_schedule_row_teacher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_col_teacher"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/home_schedule_teacher"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/text_primary"
                tools:text="الأستاذ أحمد" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/home_schedule_cancel"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lesson_cancel_short"
            android:visibility="gone"
            app:cornerRadius="@dimen/button_corner_radius" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
