<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:layoutDirection="rtl"
    android:overScrollMode="ifContentScrolls"
    android:scrollbars="none">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/scroll_screen_padding_h"
        android:paddingTop="8dp"
        android:paddingEnd="@dimen/scroll_screen_padding_h"
        android:paddingBottom="20dp">

        <include
            android:id="@+id/header_profile_edit"
            layout="@layout/custom_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_margin_vertical"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="@dimen/screen_content_card_radius"
            app:cardElevation="0dp"
            app:cardUseCompatPadding="false"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/screen_content_card_padding">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal">

                    <ImageView
                        android:id="@+id/profile_edit_photo"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:background="@drawable/bg_edittext"
                        android:contentDescription="@string/photo"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/ic_teachme_logo_small" />

                    <TextView
                        android:id="@+id/profile_edit_add_photo_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:padding="24dp"
                        android:text="@string/add_photo"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:visibility="gone" />

                    <View
                        android:id="@+id/profile_edit_photo_click"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="@string/change_photo"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/profile_edit_pick_gallery_btn"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/profile_photo_action_height"
                            android:layout_marginEnd="6dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="@dimen/profile_photo_action_padding_h"
                            android:paddingEnd="@dimen/profile_photo_action_padding_h"
                            android:text="@string/photo_from_gallery"
                            android:textSize="12sp"
                            app:cornerRadius="@dimen/button_corner_radius" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/profile_edit_pick_camera_btn"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/profile_photo_action_height"
                            android:layout_marginStart="6dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:paddingStart="@dimen/profile_photo_action_padding_h"
                            android:paddingEnd="@dimen/profile_photo_action_padding_h"
                            android:text="@string/photo_from_camera"
                            android:textSize="12sp"
                            app:cornerRadius="@dimen/button_corner_radius" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/full_name"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/profile_edit_full_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="@string/full_name_hint"
                    android:inputType="textPersonName"
                    android:paddingStart="@dimen/edittext_padding_start"
                    android:paddingEnd="@dimen/edittext_padding_end"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/hint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/phone"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/profile_edit_phone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:hint="@string/phone_hint"
                    android:inputType="phone"
                    android:paddingStart="@dimen/edittext_padding_start"
                    android:paddingEnd="@dimen/edittext_padding_end"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/hint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/email"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/profile_edit_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    tools:text="user@example.com" />

                <LinearLayout
                    android:id="@+id/profile_edit_teacher_fields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/specialization"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/profile_edit_specialization_btn"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:minHeight="48dp"
                        android:text="@string/select_subjects"
                        android:textSize="14sp"
                        app:cornerRadius="@dimen/button_corner_radius" />

                    <TextView
                        android:id="@+id/profile_edit_specialization_summary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:visibility="gone"
                        tools:text="الرياضيات، العلوم"
                        tools:visibility="visible" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/experience"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/profile_edit_experience_years"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/hourly_rate"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/profile_edit_hourly_rate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="@string/hourly_rate_hint"
                        android:inputType="numberDecimal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/profile_edit_student_fields"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/birth_date"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <Spinner
                            android:id="@+id/profile_edit_birth_day"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext" />

                        <Spinner
                            android:id="@+id/profile_edit_birth_month"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext" />

                        <Spinner
                            android:id="@+id/profile_edit_birth_year"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/grade"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <Spinner
                        android:id="@+id/profile_edit_grade_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/school"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/profile_edit_school"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_edittext"
                        android:hint="@string/school_hint"
                        android:inputType="text"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/hint" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/description"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/profile_edit_description"
                    android:layout_width="match_parent"
                    android:layout_height="96dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_edittext"
                    android:gravity="top|start"
                    android:hint="@string/description_hint_teacher"
                    android:inputType="textMultiLine"
                    android:paddingStart="16dp"
                    android:paddingTop="12dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="12dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/hint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/profile_edit_save_btn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:minHeight="48dp"
                    android:text="@string/save"
                    android:textColor="@color/white"
                    app:backgroundTint="?attr/colorPrimary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
